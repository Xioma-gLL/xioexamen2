<%- include('../partials/header') %>

<% if (flash && flash.msg) { %>
  <div class="alert alert-<%= flash.tipo %> alert-dismissible fade show" role="alert">
    <%= flash.msg %>
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
<% } %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <h2><i class="bi bi-people-fill"></i> <%= titulo %></h2>
  <a href="/clientes/nuevo" class="btn btn-primary"><i class="bi bi-plus-circle"></i> Nuevo Cliente</a>
</div>

<% if (clientes.length === 0) { %>
  <div class="alert alert-info">No hay clientes registrados.</div>
<% } else { %>
  <div class="table-responsive">
    <table class="table table-striped table-hover align-middle">
      <thead class="table-primary">
        <tr>
          <th>#</th>
          <th>Nombre</th>
          <th class="text-center">Acciones</th>
        </tr>
      </thead>
      <tbody>
        <% clientes.forEach(c => { %>
          <tr>
            <td><%= c.id_cliente %></td>
            <td><%= c.nombre %></td>
            <td class="text-center">
              <a href="/clientes/<%= c.id_cliente %>/editar" class="btn btn-sm btn-warning me-1">
                <i class="bi bi-pencil-fill"></i> Editar
              </a>
              <form action="/clientes/<%= c.id_cliente %>?_method=DELETE" method="POST" class="d-inline"
                    onsubmit="return confirm('¿Eliminar cliente?')">
                <button class="btn btn-sm btn-danger"><i class="bi bi-trash-fill"></i> Eliminar</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
<% } %>

<%- include('../partials/footer') %>
