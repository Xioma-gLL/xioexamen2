<%- include('../partials/header') %>

<div class="row justify-content-center">
  <div class="col-md-6">
    <div class="card shadow-sm">
      <div class="card-header bg-primary text-white">
        <h4 class="mb-0"><i class="bi bi-person-<%= cliente ? 'gear' : 'plus' %>-fill"></i> <%= titulo %></h4>
      </div>
      <div class="card-body">

        <% if (errores.length > 0) { %>
          <div class="alert alert-danger">
            <ul class="mb-0">
              <% errores.forEach(e => { %><li><%= e %></li><% }) %>
            </ul>
          </div>
        <% } %>

        <form action="/clientes<%= cliente ? '/' + cliente.id_cliente + '?_method=PUT' : '' %>" method="POST">
          <div class="mb-3">
            <label class="form-label fw-semibold">Nombre <span class="text-danger">*</span></label>
            <input type="text" name="nombre" class="form-control"
                   value="<%= cliente ? cliente.nombre : '' %>"
                   placeholder="Ingrese el nombre del cliente" required />
          </div>
          <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">
              <i class="bi bi-save"></i> <%= cliente ? 'Actualizar' : 'Guardar' %>
            </button>
            <a href="/clientes" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Volver</a>
          </div>
        </form>

      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
