<%- include('../partials/header') %>

<div class="row justify-content-center">
  <div class="col-md-7">
    <div class="card shadow-sm">
      <div class="card-header bg-primary text-white">
        <h4 class="mb-0"><i class="bi bi-calendar2-<%= reserva ? 'check' : 'plus' %>"></i> <%= titulo %></h4>
      </div>
      <div class="card-body">

        <% if (errores.length > 0) { %>
          <div class="alert alert-danger">
            <ul class="mb-0">
              <% errores.forEach(e => { %><li><%= e %></li><% }) %>
            </ul>
          </div>
        <% } %>

        <form
          action="/reservas<%= reserva ? '/' + reserva.id_reserva + '?_method=PUT' : '' %>"
          method="POST"
          enctype="multipart/form-data"
        >
          <!-- Cliente -->
          <div class="mb-3">
            <label class="form-label fw-semibold">Cliente <span class="text-danger">*</span></label>
            <select name="id_cliente" class="form-select" required>
              <option value="">-- Seleccione un cliente --</option>
              <% clientes.forEach(c => { %>
                <option value="<%= c.id_cliente %>"
                  <%= reserva && reserva.id_cliente == c.id_cliente ? 'selected' : '' %>>
                  <%= c.nombre %>
                </option>
              <% }) %>
            </select>
          </div>

          <!-- Fecha -->
          <div class="mb-3">
            <label class="form-label fw-semibold">Fecha <span class="text-danger">*</span></label>
            <input type="date" name="fecha" class="form-control"
                   value="<%= reserva ? reserva.fecha : '' %>" required />
          </div>

          <!-- Comprobante -->
          <div class="mb-3">
            <label class="form-label fw-semibold">Comprobante (imagen)</label>
            <% if (reserva && reserva.comprobante_img) { %>
              <div class="mb-2">
                <img src="/uploads/<%= reserva.comprobante_img %>" alt="comprobante actual"
                     class="img-thumbnail" style="max-height:120px;" />
                <p class="text-muted small mt-1">Imagen actual. Si sube otra, reemplazará a esta.</p>
              </div>
            <% } %>
            <input type="file" name="comprobante_img" class="form-control" accept="image/*" />
            <div class="form-text">Formatos: JPG, PNG, GIF, WEBP. Máx. 5 MB.</div>
          </div>

          <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">
              <i class="bi bi-save"></i> <%= reserva ? 'Actualizar' : 'Guardar' %>
            </button>
            <a href="/reservas" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Volver</a>
          </div>
        </form>

      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
