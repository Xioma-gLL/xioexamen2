<%- include('../partials/header') %>

<% if (flash && flash.msg) { %>
  <div class="alert alert-<%= flash.tipo %> alert-dismissible fade show" role="alert">
    <%= flash.msg %>
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
<% } %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <h2><i class="bi bi-journal-text"></i> <%= titulo %></h2>
  <a href="/reservas/nuevo" class="btn btn-primary"><i class="bi bi-plus-circle"></i> Nueva Reserva</a>
</div>

<% if (reservas.length === 0) { %>
  <div class="alert alert-info">No hay reservas registradas.</div>
<% } else { %>
  <div class="table-responsive">
    <table class="table table-striped table-hover align-middle">
      <thead class="table-primary">
        <tr>
          <th>#</th>
          <th>Fecha</th>
          <th>Cliente</th>
          <th class="text-center">Comprobante</th>
          <th class="text-center">Acciones</th>
        </tr>
      </thead>
      <tbody>
        <% reservas.forEach(r => { %>
          <tr>
            <td><%= r.id_reserva %></td>
            <td><%= r.fecha %></td>
            <td><%= r.cliente ? r.cliente.nombre : '—' %></td>
            <td class="text-center">
              <% if (r.comprobante_img) { %>
                <a href="/uploads/<%= r.comprobante_img %>" target="_blank">
                  <img src="/uploads/<%= r.comprobante_img %>" alt="comprobante"
                       class="img-thumbnail" style="max-height:60px;" />
                </a>
              <% } else { %>
                <span class="text-muted">Sin imagen</span>
              <% } %>
            </td>
            <td class="text-center">
              <a href="/reservas/<%= r.id_reserva %>/editar" class="btn btn-sm btn-warning me-1">
                <i class="bi bi-pencil-fill"></i> Editar
              </a>
              <form action="/reservas/<%= r.id_reserva %>?_method=DELETE" method="POST" class="d-inline"
                    onsubmit="return confirm('¿Eliminar reserva?')">
                <button class="btn btn-sm btn-danger"><i class="bi bi-trash-fill"></i> Eliminar</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
<% } %>

<%- include('../partials/footer') %>
